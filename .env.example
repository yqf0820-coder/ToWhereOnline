# Supabase 配置
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# GitHub 图片存储配置
# 注意：VITE_GITHUB_TOKEN 不再需要，Token 已通过邀请码系统加密管理
VITE_GITHUB_OWNER=your-github-username
VITE_GITHUB_REPO=your-repo-name
VITE_GITHUB_BRANCH=main

# AI 回忆生成
VITE_AI_API_KEY=your-openrouter-api-key
# VITE_AI_API_BASE=https://openrouter.ai/api/v1  (默认)
# VITE_AI_MODEL=google/gemini-2.5-flash  (默认)
